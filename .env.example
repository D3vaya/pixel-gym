# =============================================================================
# Adelgazapix — production hardening env vars
# All of these are OPTIONAL. If unset, the protection is OFF (open / dev mode).
# Copy this file to `.env.local` and fill what you want to enable.
# =============================================================================

# --- Basic Auth gate (whole site) -------------------------------------------
# When both are set, the middleware requires HTTP Basic Auth on every route.
# Browsers prompt natively and cache credentials per origin.
# ACCESS_USER=admin
# ACCESS_PASS=replace-with-a-strong-password

# --- Origin allowlist (anti-hotlinking) -------------------------------------
# Comma-separated list of allowed origins for POST/PUT/PATCH/DELETE.
#
# On Vercel, the deployment's own URLs are added automatically (VERCEL_URL,
# VERCEL_PROJECT_PRODUCTION_URL, VERCEL_BRANCH_URL). You only need to add
# custom domains. In dev, http://localhost:* is always allowed.
#
# Set this to ANY value to enable the check; leave commented to disable.
# ALLOWED_ORIGIN=https://your-custom-domain.com

# --- Rate limit (per IP, sliding window 20/min) -----------------------------
# Get free credentials at https://upstash.com (Redis → REST API).
# When set, the /api/process route enforces the limit before doing any work.
# UPSTASH_REDIS_REST_URL=https://your-id.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AYTk...replace-me

# --- Cron secret (orphan blob cleanup) --------------------------------------
# Required when the daily cron at /api/cron/cleanup runs in production.
# Vercel auto-injects `Authorization: Bearer ${CRON_SECRET}` on cron calls.
# Generate one with: openssl rand -hex 32
# CRON_SECRET=your-random-secret

# --- Vercel Blob (required for files > 4 MB in production) ------------------
# Vercel's serverless functions reject bodies > 4.5 MB. Larger uploads must
# go via Vercel Blob: client → Blob storage → server fetches → Sharp → response.
# Enable Blob in your Vercel project (Storage → Blob → Create Store), then
# run `vercel env pull` to fetch this token. Auto-injected in Vercel runtimes.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
